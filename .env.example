# OpenAI API key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Brave Search API key (optional, enables web search fallback)
BRAVE_API_KEY=your-brave-api-key-here

# HuggingFace token (optional)
HF_TOKEN=your-huggingface-token-here

# UiPath Maestro / Slack configuration (GT_ prefix)
GT_SLACK_BOT_TOKEN=xoxb-your-bot-token
GT_SLACK_SIGNING_SECRET=your-signing-secret
GT_SLACK_CHANNEL_ID=C1234567890
GT_SLACK_CANDIDATE_CHANNEL_ID=C1234567890
GT_SLACK_MANAGER_ID=U1234567890
GT_MAESTRO_WEBHOOK_SECRET=maestro-secret-change-me
